<?xml version="1.0" encoding="UTF-8"?>
	<parameters>
		<param>
			<name>konus.in.descr</name>
			<type>file</type>
			<filename>konus.in.descr</filename>
			<comment>Description of input file for konus</comment>
		</param>
		<param>
			<name>konus.in</name>
			<type>filelist</type>
			<size></size>
			<filepattern>konus_%1.in</filepattern>
			<comment>Variants of input parametes for konus</comment>
		</param>
		<param>
			<name>konus.out</name>
			<type>filelist</type>
			<size></size>
			<filepattern>konus_%1.out</filepattern>
			<comment>Result of konus calculating</comment>
		</param>
		<param>
			<name>graph</name>
			<type>file</type>
			<filename>result.png</filename>
			<comment>result</comment>
		</param>
		<param>
			<name>decomposition.count</name>
			<type>file</type>
			<filename>decomposition.num</filename>
			<comment>decomposition count</comment>
		</param>

	</parameters>

