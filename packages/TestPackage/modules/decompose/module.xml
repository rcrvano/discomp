<?xml version='1.0' encoding='UTF-8'?>
<module>
	<info>
		<name>decompose</name>
		<fullname></fullname>
		<comment></comment>
		<os></os>
		<type></type>
	</info>
	<commands>
		<start max_time='' stdout='' detached=''>./decompose.sh {PARAM_VALUE:input}</start>
		<stop detached=''></stop>
	</commands>
	<parameters>
		<input>
			<param>
				<name>input</name>
				<type>file</type>
				<comment>Input file for scheme</comment>
				<filename>input.txt</filename>
				<filepattern></filepattern>
				<constant></constant>
				<size></size>
				<regexp></regexp>
			</param>
		</input>
		<output>
			<param>
				<name>gen_list</name>
				<type>filelist</type>
				<comment>Generated List</comment>
				<filename></filename>
				<filepattern>genlist%1.txt</filepattern>
				<constant></constant>
				<size></size>
				<regexp></regexp>
			</param>
		</output>
	</parameters>
</module>
